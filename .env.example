# ── LLM APIs ────────────────────────────────────────────
# OpenAI (primary)
OPENAI_API_KEY=sk-...

# OpenRouter (fallback / cheaper models)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Model Selection ──────────────────────────────────────
# Defaults shown — override per category as needed
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ── App Config ───────────────────────────────────────────
APP_ENV=development         # development | production
DEBUG=true

# ── Category-specific (uncomment as needed) ──────────────
# Cat 1 — Avanade AI Wellbeing
# WELLBEING_DATA_PATH=data/

# Cat 2 — ISACA Cyber Safety Coach
# SAFETY_CONTENT_PATH=data/

# Cat 3 — IA West Smart Match CRM
# CRM_CSV_PATH=data/
# SPEAKER_DATA_PATH=data/

# Cat 4 — Aytm x Neo Smart Living
# SURVEY_DATA_PATH=data/
# INTERVIEW_DATA_PATH=data/

# Cat 5 — Avanade Creative SDG
# SDG_ASSETS_PATH=data/
