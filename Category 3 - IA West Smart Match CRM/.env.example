# === Gemini Configuration ===
GEMINI_API_KEY=AIza...
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# === Tavily (optional — Web Intelligence / crawler) ===
# Used by FastAPI POST /api/crawler/start when Gemini web search returns no results.
# Get a key at https://tavily.com — requires package tavily-python (see requirements.txt).
TAVILY_API_KEY=tvly-dev-...

# === Application Configuration ===
APP_ENV=development
LOG_LEVEL=INFO

# === Data Paths (relative to project root) ===
DATA_DIR=data/
CACHE_DIR=cache/

# === Embedding Configuration ===
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=20
EMBEDDING_MAX_RETRIES=3

# === Streamlit Configuration ===
STREAMLIT_PAGE_TITLE=IA SmartMatch CRM
STREAMLIT_PAGE_ICON=🔗

# === NemoClaw Configuration (Optional) ===
USE_NEMOCLAW=0
NVIDIA_NGC_API_KEY=nvapi-...
NEMOCLAW_MODEL=nemotron-mini
